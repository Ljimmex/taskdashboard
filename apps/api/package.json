{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "deploy": "wrangler deploy --config wrangler.toml",
    "typecheck": "cross-env NODE_OPTIONS=--max-old-space-size=4096 tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:reset-2fa": "bun run scripts/reset-2fa.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1081.0",
    "@aws-sdk/s3-request-presigner": "^3.1081.0",
    "@hono/zod-openapi": "^1.4.0",
    "@hono/zod-validator": "^0.8.0",
    "@polar-sh/sdk": "^0.48.1",
    "@scalar/hono-api-reference": "^0.11.8",
    "@supabase/supabase-js": "^2.110.1",
    "@taskdashboard/types": "workspace:*",
    "@taskdashboard/utils": "workspace:*",
    "better-auth": "^1.6.23",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.28",
    "hono-rate-limiter": "^0.5.3",
    "nanoid": "^5.1.16",
    "nodemailer": "^9.0.3",
    "postgres": "^3.4.9",
    "rrule": "^2.8.1",
    "sanitize-html": "^2.17.5",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/nodemailer": "^8.0.1",
    "@types/sanitize-html": "^2.16.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3"
  }
}
