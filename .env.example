# =============================================================================
# LOCAL DEVELOPMENT — copy this file to .env.local and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Backend (apps/api) — required for local API server
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taskdashboard
BETTER_AUTH_SECRET=your-better-auth-secret-min-32-chars-long
BETTER_AUTH_URL=http://localhost:3000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# OAuth (optional — only register providers that have both id and secret set)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Email (Resend) — required for OTP / email verification
RESEND_API_KEY=re_xxxxxxxx
FROM_EMAIL=noreply@yourdomain.com

# Cloudflare R2 — required for file storage
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=zadano-files

# Polar.sh — required for subscriptions / billing
# Use an Organization Access Token (OAT) starting with polar_oat_ for production.
POLAR_ENV=sandbox
POLAR_ACCESS_TOKEN=polar_oat_xxxxxxxx
POLAR_WEBHOOK_SECRET=whsec_xxxxxxxx
POLAR_PLUS_MONTHLY_PRODUCT_ID=
POLAR_PLUS_QUARTERLY_PRODUCT_ID=
POLAR_PLUS_YEARLY_PRODUCT_ID=
POLAR_PRO_MONTHLY_PRODUCT_ID=
POLAR_PRO_QUARTERLY_PRODUCT_ID=
POLAR_PRO_YEARLY_PRODUCT_ID=

# Misc
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Frontend (apps/web) — required for local Vite dev server
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:3000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
